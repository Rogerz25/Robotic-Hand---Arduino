#include <Wire.h>
#include <Adafruit_PWMServoDriver.h>
#include "DFRobot_DF2301Q.h"

// =======================
// Voice Module (I2C)
// =======================
DFRobot_DF2301Q_I2C asr;

// =======================
// PCA9685
// =======================
Adafruit_PWMServoDriver pwm = Adafruit_PWMServoDriver(0x40);

// =======================
// Servo settings
// =======================
#define SERVO_CHANNEL 0
#define SERVO_MIN 150
#define SERVO_MAX 600

uint16_t angleToPulse(int angle) {
  return map(angle, 0, 180, SERVO_MIN, SERVO_MAX);
}

void setup() {
  Serial.begin(115200);
  Wire.begin();

  // Init PCA9685
  pwm.begin();
  pwm.setPWMFreq(50);
  delay(10);

  // Init Voice Module (I2C)
  while (!asr.begin()) {
    Serial.println("Voice module not detected (I2C)");
    delay(2000);
  }

  Serial.println("Voice module ready (I2C)");

  // Start servo at 0°
  pwm.setPWM(SERVO_CHANNEL, 0, angleToPulse(0));
}

void loop() {
  uint8_t CMDID = asr.getCMDID();

  switch (CMDID) {

    case 5:   // Voice command ID 5
      Serial.println("CMDID 5 → Servo to 180°");
      pwm.setPWM(SERVO_CHANNEL, 0, angleToPulse(180));
      break;

    case 6:   // Optional second command
      Serial.println("CMDID 6 → Servo to 0°");
      pwm.setPWM(SERVO_CHANNEL, 0, angleToPulse(0));
      break;

    default:
      if (CMDID != 0) {
        Serial.print("Unknown CMDID: ");
        Serial.println(CMDID);
      }
      break;
  }

  delay(300);
}
