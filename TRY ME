// =======================
// SETUP
// =======================
void setup() 
{
  Wire.begin();

  // Initialize PCA9685
  pwm.begin();
  pwm.setPWMFreq(50);
  delay(10);

  // Initialize voice module
  while (!asr.begin()) 
  {
    delay(1000);
  }

  // Start with open hand
  openHand();
}

